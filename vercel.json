{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd web && npm install && npm run build",
  "outputDirectory": "web/.next",
  "installCommand": "echo 'install handled inside buildCommand'",
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.jjan.daeseon.ai" }],
      "destination": "https://jjan.daeseon.ai/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "kiclash.daeseon.ai" }],
      "destination": "https://jjan.daeseon.ai/:path*",
      "permanent": true
    }
  ]
}
