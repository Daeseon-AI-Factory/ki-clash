# Caddyfile — production reverse proxy + automatic HTTPS.
#
# Caddy 2.x automatically requests a Let's Encrypt certificate for the
# configured domain on first start. The DNS A record for {$API_DOMAIN}
# must already point at this server's public IP.
#
# Override the domain by setting API_DOMAIN in the environment, e.g.
#   API_DOMAIN=api.kiclash.com docker compose -f docker-compose.prod.yml up -d
# Default below is `api.kiclash.com`.

{$API_DOMAIN:api.jjan.daeseon.ai} {
    # /api/v1/ws/game/* — real-time gameplay WebSocket. Routed to the Go
    # game server (replaces the equivalent Python endpoint at higher
    # concurrency — see go-server/README.md). Both servers serve the same
    # Redis-backed state, so a comment-out of this matcher safely falls
    # back to Python.
    @gameWS {
        path /api/v1/ws/game/*
    }
    reverse_proxy @gameWS game:8001

    # Everything else — REST (auth, rooms, matchmaking, profile) plus the
    # matchmaking WebSocket — stays on the Python platform server.
    reverse_proxy api:8000

    # Compress responses (saves egress bandwidth)
    encode zstd gzip

    # Reasonable security headers
    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        # Don't leak server identity
        -Server
    }

    # Log structured access logs (useful when shipping to a log aggregator)
    log {
        output stdout
        format json
        level INFO
    }
}
