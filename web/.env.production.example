# Production env vars for Vercel.
# Set these in: Vercel dashboard → Project → Settings → Environment Variables.
# Do NOT commit real values — this file is the template only.

# Points the web client at the backend API.
# Production: https://api.jjan.daeseon.ai
NEXT_PUBLIC_API_URL=https://api.jjan.daeseon.ai

# Public site URL used by metadata, share URLs, and production verification.
NEXT_PUBLIC_SITE_URL=https://jjan.daeseon.ai

# Optional WebSocket base URL. If unset, derived from NEXT_PUBLIC_API_URL
# by swapping http→ws — so usually you don't need this. Set explicitly
# only when the WS endpoint is on a different host (e.g. a separate Go
# game server at wss://game.jjan.daeseon.ai).
# NEXT_PUBLIC_WS_URL=wss://api.jjan.daeseon.ai

# Google AdSense settings (optional). Leave blank until AdSense approves the
# site and provides real IDs. Ads render placeholders when no client is set.
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_BANNER_SLOT=
NEXT_PUBLIC_ADSENSE_INTERSTITIAL_SLOT=

# First-party launch analytics are posted to /api/analytics/events and logged
# by the Next server. No external analytics key is required for beta launch.
