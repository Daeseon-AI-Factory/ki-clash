# Copy to repo-root .env on the Naver Cloud server:
#   cp deploy/naver-cloud/.env.shared.example .env
# Replace every placeholder before starting the stack.

COMPOSE_PROJECT_NAME=jjan

# Persistent data directory on the Naver Cloud data disk.
JJAN_DATA_DIR=/data/jjan

# Localhost ports consumed by the host-level reverse proxy.
JJAN_API_PORT=18000
JJAN_GAME_PORT=18001

# Postgres
POSTGRES_USER=ki_clash
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_RANDOM
POSTGRES_DB=ki_clash

# JWT
JWT_SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_HEX

# Browser origins allowed to call the API.
CORS_ORIGINS=["https://jjan.daeseon.ai"]

# Optional observability/payments.
SENTRY_DSN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_AD_FREE_PRICE_ID=
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_FOUNDER_PASS_VARIANT_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_TEST_MODE=true
RELEASE=prod
