# Production .env template for the AWS EC2 docker-compose stack.
# Copy to `.env` (NOT in deploy/, but at repo root next to docker-compose.prod.yml):
#   cp deploy/aws-ec2/.env.prod.example .env
# Then replace every placeholder with a real value.
# NEVER commit the resulting .env — it's already in .gitignore.

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=ki_clash
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_RANDOM  # `openssl rand -base64 24`
POSTGRES_DB=ki_clash

# ── JWT (NEVER reuse across environments) ──────────────────────────────────
JWT_SECRET_KEY=REPLACE_WITH_STRONG_RANDOM  # `openssl rand -hex 32`

# ── CORS — comma-separated list, JSON array format ─────────────────────────
# Set this to your Vercel frontend URL exactly. Examples:
#   ["https://kiclash.daeseon.ai"]
#   ["https://kiclash.daeseon.ai","https://kiclash.vercel.app"]
CORS_ORIGINS=["https://kiclash.daeseon.ai"]

# ── Reverse-proxy domain (read by Caddyfile) ────────────────────────────────
API_DOMAIN=api.kiclash.daeseon.ai

# ── Sentry (optional — leave blank to disable error tracking) ──────────────
SENTRY_DSN=

# ── Stripe (optional — leave blank to disable payment flows) ───────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_AD_FREE_PRICE_ID=

# ── Lemon Squeezy (optional — Founder Pass hosted checkout) ───────────────
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_FOUNDER_PASS_VARIANT_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_TEST_MODE=true
