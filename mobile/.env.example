# Ki Clash — Mobile Environment Config
# Expo reads EXPO_PUBLIC_* variables at build time.

# Production backend API URL
EXPO_PUBLIC_API_URL=https://api.jjan.daeseon.ai

# Production WebSocket URL — same host as API, different protocol
EXPO_PUBLIC_WS_URL=wss://api.jjan.daeseon.ai

# Official web / promo URL used by share links
EXPO_PUBLIC_WEB_URL=https://jjan.daeseon.ai
